{
  "$schema": "https://tr.designtokens.org/format/",
  "$metadata": {
    "brand": "Rautaki",
    "version": "1.0.0",
    "description": "W3C DTCG design tokens. Use with Tokens Studio (Figma) or Style Dictionary."
  },

  "color": {
    "$type": "color",

    "gold": {
      "500": { "$value": "#F5A623", "$description": "Brand accent — primary gold" },
      "300": { "$value": "#FFD07A", "$description": "Gold light — hover tints" },
      "900": { "$value": "#B87400", "$description": "Deep gold — high-contrast contexts only" },
      "alpha-15": { "$value": "rgba(245, 166, 35, 0.15)", "$description": "Dim gold fill — tags, ghost backgrounds" },
      "alpha-08": { "$value": "rgba(245, 166, 35, 0.08)", "$description": "Hero ambient glow" }
    },

    "dark": {
      "obsidian": { "$value": "#0A0A0A", "$description": "Deepest dark — hero, footer, card section" },
      "ink":      { "$value": "#1C1C1C", "$description": "Near-black — body text on light surfaces" },
      "charcoal": { "$value": "#111111", "$description": "Card surface on dark" },
      "charcoal-hover": { "$value": "#161616", "$description": "Card surface on hover" }
    },

    "light": {
      "white":      { "$value": "#FAFAFA", "$description": "Off-white — clean surfaces" },
      "cream":      { "$value": "#F4F2EE", "$description": "Warm off-white — page default, section alternates" },
      "warm-grey":  { "$value": "#E8E5DF", "$description": "Warm light grey — social card section" },
      "email-bg":   { "$value": "#DDD9D0", "$description": "Email section backdrop" }
    },

    "grey": {
      "mid": { "$value": "#9A9590", "$description": "Secondary text — captions, meta, muted labels" }
    },

    "alpha": {
      "white-45":   { "$value": "rgba(255, 255, 255, 0.45)", "$description": "Body copy on dark" },
      "white-28":   { "$value": "rgba(255, 255, 255, 0.28)", "$description": "Navigation, contact info on dark" },
      "white-20":   { "$value": "rgba(255, 255, 255, 0.20)", "$description": "Footer copy, email labels" },
      "white-05":   { "$value": "rgba(255, 255, 255, 0.05)", "$description": "Subtle dark dividers" },
      "white-025":  { "$value": "rgba(255, 255, 255, 0.025)", "$description": "Watermark R letterform" },
      "ink-45":     { "$value": "rgba(28, 28, 28, 0.45)", "$description": "Muted text on light" },
      "ink-10":     { "$value": "rgba(28, 28, 28, 0.10)", "$description": "Hair rules on light" },
      "ink-07":     { "$value": "rgba(28, 28, 28, 0.07)", "$description": "Very subtle dividers" },
      "ink-06":     { "$value": "rgba(28, 28, 28, 0.06)", "$description": "Logo cell borders on white" }
    },

    "semantic": {
      "accent":           { "$value": "{color.gold.500}" },
      "accent-light":     { "$value": "{color.gold.300}" },
      "accent-dim":       { "$value": "{color.gold.alpha-15}" },

      "bg-dark":          { "$value": "{color.dark.obsidian}" },
      "bg-light":         { "$value": "{color.light.white}" },
      "bg-cream":         { "$value": "{color.light.cream}" },
      "bg-warm":          { "$value": "{color.light.warm-grey}" },
      "bg-card-dark":     { "$value": "{color.dark.charcoal}" },
      "bg-card-hover":    { "$value": "{color.dark.charcoal-hover}" },

      "text-primary":     { "$value": "{color.dark.ink}" },
      "text-secondary":   { "$value": "{color.grey.mid}" },
      "text-muted":       { "$value": "{color.alpha.ink-45}" },
      "text-accent":      { "$value": "{color.gold.500}" },
      "text-on-dark":     { "$value": "{color.light.white}" },
      "text-on-dark-body":{ "$value": "{color.alpha.white-45}" },
      "text-on-dark-sub": { "$value": "{color.alpha.white-28}" },
      "text-on-dark-muted":{ "$value": "{color.alpha.white-20}" },

      "border-gold":      { "$value": "{color.gold.500}" },
      "border-subtle":    { "$value": "{color.alpha.ink-07}" },
      "border-hair":      { "$value": "{color.alpha.ink-10}" },
      "border-dark":      { "$value": "{color.alpha.white-05}" }
    }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "serif":  { "$value": ["Georgia", "Times New Roman", "serif"], "$description": "Primary — headings, logo, display, stats" },
      "ui":     { "$value": ["DM Sans", "system-ui", "sans-serif"], "$description": "Secondary — body, labels, navigation, UI" },
      "mono":   { "$value": ["Menlo", "Consolas", "monospace"], "$description": "Code/token references in design docs" }
    },

    "weight": {
      "$type": "fontWeight",
      "light":   { "$value": 300, "$description": "DM Sans light — body on dark, hero body" },
      "regular": { "$value": 400, "$description": "DM Sans + Georgia — standard" },
      "medium":  { "$value": 500, "$description": "DM Sans — labels, buttons, navigation" }
    }
  },

  "size": {
    "$type": "dimension",
    "hero":    { "$value": "88px",  "$description": "Hero display — homepage banners" },
    "d1":      { "$value": "64px",  "$description": "Display D1 — section openers, large numerics" },
    "h1":      { "$value": "48px",  "$description": "H1 — page titles" },
    "h2":      { "$value": "36px",  "$description": "H2 — section headings" },
    "h3":      { "$value": "26px",  "$description": "H3 — cards, pull quotes" },
    "h4":      { "$value": "20px",  "$description": "H4 — sub-sections" },
    "lead":    { "$value": "18px",  "$description": "Lead — first paragraph, italic emphasis" },
    "body":    { "$value": "15px",  "$description": "Body — all running copy" },
    "sm":      { "$value": "13px",  "$description": "Small — footnotes, meta" },
    "xs":      { "$value": "11px",  "$description": "XS — labels, captions, section markers" },
    "logo-xl": { "$value": "56px",  "$description": "Logo XL — hero, cover pages" },
    "logo-md": { "$value": "36px",  "$description": "Logo MD — page headers" },
    "logo-sm": { "$value": "24px",  "$description": "Logo SM — navigation, cards" },
    "logo-xs": { "$value": "18px",  "$description": "Logo XS — minimum digital size" }
  },

  "lineHeight": {
    "display":  { "$value": "1.0",  "$description": "Hero, D1" },
    "heading":  { "$value": "1.15", "$description": "H1–H3" },
    "subhead":  { "$value": "1.25", "$description": "H4, pull quotes" },
    "body":     { "$value": "1.75", "$description": "All running copy" },
    "ui":       { "$value": "1.5",  "$description": "Labels, captions" },
    "loose":    { "$value": "1.8",  "$description": "Contact text, specimens" },
    "card":     { "$value": "1.45", "$description": "Social card quotes" }
  },

  "letterSpacing": {
    "hero":         { "$value": "-0.04em", "$description": "88px hero" },
    "d1":           { "$value": "-0.03em", "$description": "64px display" },
    "h1":           { "$value": "-0.03em", "$description": "48px heading" },
    "h2":           { "$value": "-0.02em", "$description": "36px heading" },
    "h3":           { "$value": "-0.015em","$description": "26px heading" },
    "h4":           { "$value": "-0.01em", "$description": "20px heading" },
    "body":         { "$value": "0em",     "$description": "Body — trust Georgia/DM Sans defaults" },
    "label-wide":   { "$value": "0.22em",  "$description": "Section labels, logo tagline" },
    "label-mid":    { "$value": "0.18em",  "$description": "Stat labels, breadcrumbs" },
    "label-tight":  { "$value": "0.12em",  "$description": "Email header, swatch names" },
    "btn":          { "$value": "0.20em",  "$description": "Buttons" },
    "nav":          { "$value": "0.16em",  "$description": "Navigation items" },
    "footer":       { "$value": "0.15em",  "$description": "Footer copy" }
  },

  "spacing": {
    "$type": "dimension",
    "1":   { "$value": "4px" },
    "2":   { "$value": "8px" },
    "3":   { "$value": "12px" },
    "4":   { "$value": "16px" },
    "5":   { "$value": "20px" },
    "6":   { "$value": "24px" },
    "7":   { "$value": "28px" },
    "8":   { "$value": "32px" },
    "9":   { "$value": "36px" },
    "10":  { "$value": "40px" },
    "12":  { "$value": "48px" },
    "14":  { "$value": "56px" },
    "15":  { "$value": "60px" },
    "20":  { "$value": "80px",  "$description": "Standard section padding" },
    "25":  { "$value": "100px", "$description": "Large section padding" }
  },

  "borderWidth": {
    "gold-rule":  { "$value": "3px", "$description": "Footer top, hero-light top, card hover" },
    "gold-thin":  { "$value": "2px", "$description": "Type-scale top, stat left-border" },
    "gold-hair":  { "$value": "1px", "$description": "Section-label line" },
    "subtle":     { "$value": "1px" }
  },

  "shadow": {
    "none":   { "$value": "none" },
    "email":  { "$value": "0 24px 80px rgba(0, 0, 0, 0.14)", "$description": "Email template wrapper" },
    "card":   { "$value": "0 8px 32px rgba(0, 0, 0, 0.10)",  "$description": "Light-mode card elevation" },
    "modal":  { "$value": "0 32px 96px rgba(0, 0, 0, 0.20)", "$description": "Modals and overlays" }
  },

  "duration": {
    "$type": "duration",
    "instant": { "$value": "80ms" },
    "fast":    { "$value": "150ms" },
    "base":    { "$value": "200ms", "$description": "Standard hover/focus transitions" },
    "slow":    { "$value": "400ms", "$description": "Card border reveal" },
    "xslow":   { "$value": "600ms", "$description": "Page-level transitions" }
  },

  "breakpoint": {
    "sm":  { "$value": "480px",  "$description": "Small mobile" },
    "md":  { "$value": "768px",  "$description": "Tablet portrait" },
    "lg":  { "$value": "1024px", "$description": "Tablet landscape / laptop" },
    "xl":  { "$value": "1280px", "$description": "Desktop" },
    "2xl": { "$value": "1440px", "$description": "Wide desktop — max content width" }
  }
}